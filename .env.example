# Example environment variables for the public GitHub edition.
# This file is a reference template only. Export these values in your shell
# or CI environment; Spring Boot does not automatically load .env files.

SERVER_PORT=8080

# Optional LLM configuration.
LLM_PROVIDER=GLM
LLM_MODEL=glm-5.1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_API_KEY=

# Optional stdio MCP runtime examples.
AMAP_MCP_COMMAND=npx
AMAP_MAPS_API_KEY=
TRAIN_12306_MCP_COMMAND=npx

# Optional remote MCP example.
REMOTE_MCP_URL=
REMOTE_MCP_TOKEN=
